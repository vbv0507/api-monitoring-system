<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>API Monitoring Console</title>
    <meta name="theme-color" content="#0f766e">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ["Inter", "ui-sans-serif", "system-ui", "sans-serif"],
                    },
                    boxShadow: {
                        soft: "0 18px 60px rgba(15, 23, 42, 0.12)",
                    },
                },
            },
        };
    </script>
    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js" defer></script>
</head>
<body class="min-h-screen bg-[#f4f7f5] font-sans text-slate-950 antialiased">
    <main class="min-h-screen">
        <section id="authSection" class="min-h-screen">
            <div class="mx-auto grid min-h-screen w-full max-w-7xl lg:grid-cols-[0.95fr_1.05fr]">
                <aside class="flex flex-col justify-between bg-slate-950 px-5 py-6 text-white sm:px-8 lg:px-10">
                    <div>
                        <div class="flex items-center justify-between gap-4">
                            <a href="/" class="flex items-center gap-3 font-semibold">
                                <span class="grid h-10 w-10 place-items-center rounded-lg bg-teal-400 text-slate-950">
                                    <i data-lucide="activity" class="h-5 w-5"></i>
                                </span>
                                <span>PulseOps</span>
                            </a>
                            <a href="#authCard" class="rounded-lg border border-white/15 px-4 py-2 text-sm font-semibold text-white/80 transition hover:bg-white/10 hover:text-white">Account</a>
                        </div>

                        <div class="mt-16 max-w-xl lg:mt-24">
                            <span class="inline-flex items-center gap-2 rounded-lg bg-white/10 px-3 py-2 text-sm font-semibold text-teal-100">
                                <i data-lucide="radar" class="h-4 w-4"></i>
                                API health monitoring
                            </span>
                            <h1 class="mt-7 text-5xl font-black leading-none text-white sm:text-6xl lg:text-7xl">
                                Know when your APIs need attention.
                            </h1>
                            <p class="mt-6 max-w-lg text-base leading-7 text-slate-300 sm:text-lg">
                                Track endpoint status, response time, failures, and check history from a focused control room built for fast decisions.
                            </p>
                        </div>
                    </div>

                    <div class="mt-12 grid gap-3 sm:grid-cols-3">
                        <div class="rounded-lg border border-white/10 bg-white/5 p-4">
                            <p class="text-3xl font-black text-teal-300">60s</p>
                            <p class="mt-1 text-sm text-slate-300">Fast check cycle</p>
                        </div>
                        <div class="rounded-lg border border-white/10 bg-white/5 p-4">
                            <p class="text-3xl font-black text-emerald-300">UP</p>
                            <p class="mt-1 text-sm text-slate-300">Live status view</p>
                        </div>
                        <div class="rounded-lg border border-white/10 bg-white/5 p-4">
                            <p class="text-3xl font-black text-amber-300">4</p>
                            <p class="mt-1 text-sm text-slate-300">HTTP methods</p>
                        </div>
                    </div>
                </aside>

                <section class="flex items-center bg-[#f4f7f5] px-5 py-8 sm:px-8 lg:px-12">
                    <div id="authCard" class="w-full rounded-lg border border-slate-200 bg-white p-5 shadow-soft sm:p-8">
                        <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                            <div>
                                <p class="text-sm font-bold uppercase text-teal-700">Secure workspace</p>
                                <h2 class="mt-2 text-3xl font-black text-slate-950">Start monitoring</h2>
                                <p class="mt-2 max-w-xl leading-7 text-slate-600">Create your account or sign in to manage protected API monitors.</p>
                            </div>
                            <div class="grid grid-cols-2 gap-2 rounded-lg bg-slate-100 p-1">
                                <button id="showRegisterBtn" class="auth-toggle rounded-md bg-white px-4 py-3 text-sm font-bold text-slate-950 shadow-sm" type="button">Register</button>
                                <button id="showLoginBtn" class="auth-toggle rounded-md px-4 py-3 text-sm font-bold text-slate-500" type="button">Login</button>
                            </div>
                        </div>

                        <div class="mt-8">
                            <section id="signupPanel" class="auth-panel">
                                <form id="registerForm" class="grid gap-4" novalidate>
                                    <div class="grid gap-4 sm:grid-cols-2">
                                        <label class="grid gap-2 text-sm font-bold text-slate-700">
                                            Name
                                            <input name="name" type="text" class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-base font-medium outline-none transition focus:border-teal-600 focus:bg-white focus:ring-4 focus:ring-teal-100" placeholder="Your full name" required>
                                        </label>
                                        <label class="grid gap-2 text-sm font-bold text-slate-700">
                                            Email
                                            <input name="email" type="email" class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-base font-medium outline-none transition focus:border-teal-600 focus:bg-white focus:ring-4 focus:ring-teal-100" placeholder="you@example.com" required>
                                        </label>
                                    </div>
                                    <div class="grid gap-4 sm:grid-cols-2">
                                        <label class="grid gap-2 text-sm font-bold text-slate-700">
                                            User ID
                                            <input name="userID" type="text" class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-base font-medium outline-none transition focus:border-teal-600 focus:bg-white focus:ring-4 focus:ring-teal-100" placeholder="ops-admin" required>
                                        </label>
                                        <label class="grid gap-2 text-sm font-bold text-slate-700">
                                            Password
                                            <input name="password" type="password" class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-base font-medium outline-none transition focus:border-teal-600 focus:bg-white focus:ring-4 focus:ring-teal-100" placeholder="Create a password" required>
                                        </label>
                                    </div>
                                    <button type="submit" class="inline-flex min-h-12 items-center justify-center gap-2 rounded-lg bg-teal-700 px-5 py-3 font-bold text-white transition hover:bg-teal-800 focus:outline-none focus:ring-4 focus:ring-teal-200">
                                        <i data-lucide="user-plus" class="h-5 w-5"></i>
                                        Create account
                                    </button>
                                </form>
                            </section>

                            <section id="loginPanel" class="auth-panel hidden">
                                <form id="loginForm" class="grid gap-4" novalidate>
                                    <label class="grid gap-2 text-sm font-bold text-slate-700">
                                        User ID
                                        <input name="userID" type="text" class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-base font-medium outline-none transition focus:border-teal-600 focus:bg-white focus:ring-4 focus:ring-teal-100" placeholder="Enter your user id" required>
                                    </label>
                                    <label class="grid gap-2 text-sm font-bold text-slate-700">
                                        Password
                                        <input name="password" type="password" class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-base font-medium outline-none transition focus:border-teal-600 focus:bg-white focus:ring-4 focus:ring-teal-100" placeholder="Enter your password" required>
                                    </label>
                                    <button type="submit" class="inline-flex min-h-12 items-center justify-center gap-2 rounded-lg bg-teal-700 px-5 py-3 font-bold text-white transition hover:bg-teal-800 focus:outline-none focus:ring-4 focus:ring-teal-200">
                                        <i data-lucide="log-in" class="h-5 w-5"></i>
                                        Sign in
                                    </button>
                                </form>
                            </section>
                        </div>

                        <p id="messageBox" class="mt-5 min-h-6 rounded-lg text-sm font-semibold" role="status" aria-live="polite"></p>
                    </div>
                </section>
            </div>
        </section>

        <section id="dashboardSection" class="hidden min-h-screen bg-[#f4f7f5]">
            <header class="border-b border-slate-200 bg-white">
                <div class="mx-auto flex max-w-7xl flex-col gap-4 px-5 py-5 sm:px-8 lg:flex-row lg:items-center lg:justify-between">
                    <div class="flex items-center gap-3">
                        <span class="grid h-11 w-11 place-items-center rounded-lg bg-slate-950 text-teal-300">
                            <i data-lucide="activity" class="h-5 w-5"></i>
                        </span>
                        <div>
                            <p class="text-sm font-bold text-teal-700">PulseOps</p>
                            <h1 class="text-2xl font-black text-slate-950">Monitoring dashboard</h1>
                        </div>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        <button id="refreshBtn" type="button" class="inline-flex min-h-11 items-center justify-center gap-2 rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-bold text-slate-700 transition hover:border-teal-600 hover:text-teal-700">
                            <i data-lucide="refresh-cw" class="h-4 w-4"></i>
                            Refresh
                        </button>
                        <button id="logoutBtn" type="button" class="inline-flex min-h-11 items-center justify-center gap-2 rounded-lg bg-slate-950 px-4 py-2 text-sm font-bold text-white transition hover:bg-slate-800">
                            <i data-lucide="log-out" class="h-4 w-4"></i>
                            Sign out
                        </button>
                    </div>
                </div>
            </header>

            <div class="mx-auto grid max-w-7xl gap-5 px-5 py-6 sm:px-8 lg:grid-cols-[360px_1fr]">
                <aside class="grid content-start gap-5">
                    <section class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
                        <p class="text-sm font-bold uppercase text-slate-500">Fleet summary</p>
                        <div class="mt-5 grid grid-cols-3 gap-3">
                            <div class="rounded-lg bg-slate-100 p-4">
                                <p class="text-sm font-bold text-slate-500">Total</p>
                                <strong id="totalCount" class="mt-2 block text-3xl font-black">0</strong>
                            </div>
                            <div class="rounded-lg bg-emerald-50 p-4">
                                <p class="text-sm font-bold text-emerald-700">Up</p>
                                <strong id="upCount" class="mt-2 block text-3xl font-black text-emerald-700">0</strong>
                            </div>
                            <div class="rounded-lg bg-rose-50 p-4">
                                <p class="text-sm font-bold text-rose-700">Down</p>
                                <strong id="downCount" class="mt-2 block text-3xl font-black text-rose-700">0</strong>
                            </div>
                        </div>
                    </section>

                    <section class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
                        <div class="flex items-center gap-3">
                            <span class="grid h-10 w-10 place-items-center rounded-lg bg-teal-50 text-teal-700">
                                <i data-lucide="plus" class="h-5 w-5"></i>
                            </span>
                            <div>
                                <h2 id="monitorFormTitle" class="text-xl font-black">New monitor</h2>
                                <p id="monitorFormHelp" class="text-sm text-slate-500">Add one endpoint at a time.</p>
                            </div>
                        </div>

                        <form id="monitorForm" class="mt-5 grid gap-4">
                            <input name="id" type="hidden">
                            <label class="grid gap-2 text-sm font-bold text-slate-700">
                                API URL
                                <input name="url" type="url" class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-base font-medium outline-none transition focus:border-teal-600 focus:bg-white focus:ring-4 focus:ring-teal-100" placeholder="https://api.site.com/health" required>
                            </label>
                            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
                                <label class="grid gap-2 text-sm font-bold text-slate-700">
                                    Method
                                    <select name="method" class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-base font-bold outline-none transition focus:border-teal-600 focus:bg-white focus:ring-4 focus:ring-teal-100">
                                        <option value="GET">GET</option>
                                        <option value="POST">POST</option>
                                        <option value="PUT">PUT</option>
                                        <option value="DELETE">DELETE</option>
                                    </select>
                                </label>
                                <label class="grid gap-2 text-sm font-bold text-slate-700">
                                    Interval
                                    <select name="interval" class="rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-base font-bold outline-none transition focus:border-teal-600 focus:bg-white focus:ring-4 focus:ring-teal-100">
                                        <option value="60000">Every 1 minute</option>
                                        <option value="300000">Every 5 minutes</option>
                                        <option value="900000">Every 15 minutes</option>
                                    </select>
                                </label>
                            </div>
                            <div class="grid gap-2 sm:grid-cols-2 lg:grid-cols-1">
                                <button id="submitMonitorBtn" type="submit" class="inline-flex min-h-12 items-center justify-center gap-2 rounded-lg bg-teal-700 px-5 py-3 font-bold text-white transition hover:bg-teal-800 focus:outline-none focus:ring-4 focus:ring-teal-200">
                                    <i data-lucide="circle-plus" class="h-5 w-5"></i>
                                    Add monitor
                                </button>
                                <button id="cancelEditBtn" type="button" class="hidden min-h-12 items-center justify-center gap-2 rounded-lg border border-slate-200 bg-white px-5 py-3 font-bold text-slate-700 transition hover:border-teal-600 hover:text-teal-700">
                                    <i data-lucide="x" class="h-5 w-5"></i>
                                    Cancel edit
                                </button>
                            </div>
                        </form>
                    </section>
                </aside>

                <section class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm sm:p-6">
                    <div class="flex flex-col gap-3 border-b border-slate-200 pb-5 sm:flex-row sm:items-end sm:justify-between">
                        <div>
                            <p class="text-sm font-bold uppercase text-teal-700">Live endpoints</p>
                            <h2 class="mt-1 text-3xl font-black text-slate-950">Monitor list</h2>
                        </div>
                        <p class="max-w-md text-sm leading-6 text-slate-500">Cron checks update your saved endpoints. Refresh anytime to pull the newest status from the backend.</p>
                    </div>

                    <section id="monitorList" class="mt-5 grid gap-3"></section>

                    <div id="emptyState" class="mt-5 rounded-lg border border-dashed border-slate-300 bg-slate-50 p-10 text-center">
                        <span class="mx-auto grid h-12 w-12 place-items-center rounded-lg bg-white text-slate-500 shadow-sm">
                            <i data-lucide="monitor-dot" class="h-6 w-6"></i>
                        </span>
                        <h3 class="mt-4 text-xl font-black">No monitors yet</h3>
                        <p class="mx-auto mt-2 max-w-sm text-sm leading-6 text-slate-500">Add your first health endpoint and it will show up here with status, response time, and failures.</p>
                    </div>
                </section>
            </div>
        </section>

        <section id="logsModal" class="fixed inset-0 z-50 hidden bg-slate-950/60 px-4 py-6">
            <div class="mx-auto flex max-h-full w-full max-w-4xl flex-col rounded-lg bg-white shadow-soft">
                <div class="flex items-start justify-between gap-4 border-b border-slate-200 p-5">
                    <div class="min-w-0">
                        <p class="text-sm font-bold uppercase text-teal-700">Check history</p>
                        <h2 id="logsTitle" class="mt-1 break-all text-2xl font-black text-slate-950">Monitor logs</h2>
                    </div>
                    <button id="closeLogsBtn" type="button" class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg border border-slate-200 text-slate-600 transition hover:border-slate-400 hover:text-slate-950">
                        <i data-lucide="x" class="h-5 w-5"></i>
                    </button>
                </div>
                <div id="logsList" class="grid gap-3 overflow-y-auto p-5"></div>
            </div>
        </section>
    </main>

    <script>
        const API_BASE = "";

        const authSection = document.getElementById("authSection");
        const dashboardSection = document.getElementById("dashboardSection");
        const registerForm = document.getElementById("registerForm");
        const loginForm = document.getElementById("loginForm");
        const monitorForm = document.getElementById("monitorForm");
        const monitorList = document.getElementById("monitorList");
        const emptyState = document.getElementById("emptyState");
        const messageBox = document.getElementById("messageBox");
        const logoutBtn = document.getElementById("logoutBtn");
        const refreshBtn = document.getElementById("refreshBtn");
        const showRegisterBtn = document.getElementById("showRegisterBtn");
        const showLoginBtn = document.getElementById("showLoginBtn");
        const signupPanel = document.getElementById("signupPanel");
        const loginPanel = document.getElementById("loginPanel");
        const monitorFormTitle = document.getElementById("monitorFormTitle");
        const monitorFormHelp = document.getElementById("monitorFormHelp");
        const submitMonitorBtn = document.getElementById("submitMonitorBtn");
        const cancelEditBtn = document.getElementById("cancelEditBtn");
        const logsModal = document.getElementById("logsModal");
        const logsTitle = document.getElementById("logsTitle");
        const logsList = document.getElementById("logsList");
        const closeLogsBtn = document.getElementById("closeLogsBtn");
        let currentMonitors = [];

        function refreshIcons() {
            if (window.lucide) {
                window.lucide.createIcons();
            }
        }

        function getToken() {
            return localStorage.getItem("api_monitor_token");
        }

        function setToken(token) {
            localStorage.setItem("api_monitor_token", token);
        }

        function clearToken() {
            localStorage.removeItem("api_monitor_token");
        }

        function showMessage(message, type = "success") {
            const color = type === "error" ? "bg-rose-50 text-rose-700" : "bg-emerald-50 text-emerald-700";
            messageBox.textContent = message;
            messageBox.className = `mt-5 min-h-6 rounded-lg px-4 py-3 text-sm font-semibold ${color}`;
        }

        function hideMessage() {
            messageBox.textContent = "";
            messageBox.className = "mt-5 min-h-6 rounded-lg text-sm font-semibold";
        }

        function getFormData(form) {
            return Object.fromEntries(new FormData(form).entries());
        }

        async function apiRequest(path, options = {}) {
            const headers = {
                "Content-Type": "application/json",
                ...(options.headers || {}),
            };

            const token = getToken();
            if (token) {
                headers.Authorization = `Bearer ${token}`;
            }

            const response = await fetch(`${API_BASE}${path}`, {
                ...options,
                headers,
            });

            const data = await response.json().catch(() => ({}));
            if (!response.ok) {
                throw new Error(data.message || "Request failed");
            }

            return data;
        }

        function setAuthMode(mode) {
            const registerMode = mode === "register";
            signupPanel.classList.toggle("hidden", !registerMode);
            loginPanel.classList.toggle("hidden", registerMode);
            showRegisterBtn.className = registerMode
                ? "auth-toggle rounded-md bg-white px-4 py-3 text-sm font-bold text-slate-950 shadow-sm"
                : "auth-toggle rounded-md px-4 py-3 text-sm font-bold text-slate-500";
            showLoginBtn.className = registerMode
                ? "auth-toggle rounded-md px-4 py-3 text-sm font-bold text-slate-500"
                : "auth-toggle rounded-md bg-white px-4 py-3 text-sm font-bold text-slate-950 shadow-sm";
        }

        function updateView() {
            const loggedIn = Boolean(getToken());
            authSection.classList.toggle("hidden", loggedIn);
            dashboardSection.classList.toggle("hidden", !loggedIn);

            if (loggedIn) {
                loadMonitors();
            }

            refreshIcons();
        }

        function updateCounts(monitors) {
            const up = monitors.filter((monitor) => monitor.status === "UP").length;
            const down = monitors.filter((monitor) => monitor.status === "DOWN").length;

            document.getElementById("totalCount").textContent = monitors.length;
            document.getElementById("upCount").textContent = up;
            document.getElementById("downCount").textContent = down;
        }

        function formatDate(value) {
            if (!value) return "Not checked yet";
            return new Date(value).toLocaleString();
        }

        function formatInterval(value) {
            const minutes = Math.max(1, Math.round(Number(value || 60000) / 60000));
            return minutes === 1 ? "1 min" : `${minutes} min`;
        }

        function getStatusCodeLabel(value) {
            return value ? String(value) : "No code";
        }

        function resetMonitorForm() {
            monitorForm.reset();
            monitorForm.elements.id.value = "";
            monitorFormTitle.textContent = "New monitor";
            monitorFormHelp.textContent = "Add one endpoint at a time.";
            submitMonitorBtn.innerHTML = `<i data-lucide="circle-plus" class="h-5 w-5"></i>Add monitor`;
            cancelEditBtn.classList.add("hidden");
            cancelEditBtn.classList.remove("inline-flex");
            refreshIcons();
        }

        function editMonitor(monitor) {
            monitorForm.elements.id.value = monitor._id;
            monitorForm.elements.url.value = monitor.url || "";
            monitorForm.elements.method.value = monitor.method || "GET";
            monitorForm.elements.interval.value = String(monitor.interval || 60000);
            monitorFormTitle.textContent = "Edit monitor";
            monitorFormHelp.textContent = "Update the selected endpoint.";
            submitMonitorBtn.innerHTML = `<i data-lucide="save" class="h-5 w-5"></i>Save changes`;
            cancelEditBtn.classList.remove("hidden");
            cancelEditBtn.classList.add("inline-flex");
            monitorForm.scrollIntoView({ behavior: "smooth", block: "center" });
            refreshIcons();
        }

        function renderLogs(logs) {
            logsList.innerHTML = "";

            if (!logs.length) {
                logsList.innerHTML = `
                    <div class="rounded-lg border border-dashed border-slate-300 bg-slate-50 p-8 text-center">
                        <h3 class="text-lg font-black">No logs yet</h3>
                        <p class="mt-2 text-sm text-slate-500">After the cron check runs, status history will appear here.</p>
                    </div>
                `;
                return;
            }

            logs.forEach((log) => {
                const isDown = log.status === "DOWN";
                const row = document.createElement("article");
                row.className = "grid gap-3 rounded-lg border border-slate-200 bg-white p-4 sm:grid-cols-[1fr_120px_140px_180px] sm:items-center";
                row.innerHTML = `
                    <div class="flex items-center gap-2">
                        <span class="inline-flex items-center gap-1 rounded-lg px-2.5 py-1 text-xs font-black ring-1 ${isDown ? "bg-rose-50 text-rose-700 ring-rose-100" : "bg-emerald-50 text-emerald-700 ring-emerald-100"}">
                            <i data-lucide="${isDown ? "x-circle" : "check-circle-2"}" class="h-3.5 w-3.5"></i>
                            ${log.status}
                        </span>
                    </div>
                    <div>
                        <p class="text-xs font-bold uppercase text-slate-500">Code</p>
                        <p class="font-black text-slate-950">${getStatusCodeLabel(log.statusCode)}</p>
                    </div>
                    <div>
                        <p class="text-xs font-bold uppercase text-slate-500">Response</p>
                        <p class="font-black text-slate-950">${log.responseTime || 0}ms</p>
                    </div>
                    <div>
                        <p class="text-xs font-bold uppercase text-slate-500">Checked</p>
                        <p class="text-sm font-bold text-slate-700">${formatDate(log.createdAt)}</p>
                    </div>
                `;
                logsList.appendChild(row);
            });

            refreshIcons();
        }

        async function openLogs(monitor) {
            logsTitle.textContent = monitor.url;
            logsList.innerHTML = `
                <div class="rounded-lg bg-slate-50 p-5 text-sm font-bold text-slate-500">Loading logs...</div>
            `;
            logsModal.classList.remove("hidden");
            logsModal.classList.add("grid", "place-items-center");
            refreshIcons();

            try {
                const data = await apiRequest(`/api/monitors/${monitor._id}/logs`);
                renderLogs(data.logs || []);
            } catch (error) {
                logsList.innerHTML = `
                    <div class="rounded-lg bg-rose-50 p-5 text-sm font-bold text-rose-700">${error.message}</div>
                `;
            }
        }

        function closeLogs() {
            logsModal.classList.add("hidden");
            logsModal.classList.remove("grid", "place-items-center");
            logsList.innerHTML = "";
        }

        function renderMonitors(monitors) {
            monitorList.innerHTML = "";
            emptyState.classList.toggle("hidden", monitors.length > 0);

            monitors.forEach((monitor) => {
                const isDown = monitor.status === "DOWN";
                const statusClass = isDown ? "bg-rose-50 text-rose-700 ring-rose-100" : "bg-emerald-50 text-emerald-700 ring-emerald-100";
                const borderClass = isDown ? "border-l-rose-500" : "border-l-emerald-500";

                const card = document.createElement("article");
                card.className = `rounded-lg border border-slate-200 border-l-4 ${borderClass} bg-white p-4 transition hover:border-slate-300 hover:shadow-sm`;
                card.innerHTML = `
                    <div class="flex flex-col gap-4 xl:flex-row xl:items-center xl:justify-between">
                        <div class="min-w-0">
                            <div class="flex flex-wrap items-center gap-2">
                                <span class="inline-flex items-center gap-1 rounded-lg px-2.5 py-1 text-xs font-black ring-1 ${statusClass}">
                                    <i data-lucide="${isDown ? "x-circle" : "check-circle-2"}" class="h-3.5 w-3.5"></i>
                                    ${monitor.status || "UP"}
                                </span>
                                <span class="rounded-lg bg-slate-100 px-2.5 py-1 text-xs font-black text-slate-700">${monitor.method || "GET"}</span>
                                <span class="rounded-lg bg-slate-100 px-2.5 py-1 text-xs font-bold text-slate-500">Every ${formatInterval(monitor.interval)}</span>
                            </div>
                            <p class="mt-3 break-all text-base font-black text-slate-950">${monitor.url}</p>
                        </div>

                        <div class="grid gap-3 sm:grid-cols-4 xl:min-w-[560px]">
                            <div class="rounded-lg bg-slate-50 p-3">
                                <p class="text-xs font-bold uppercase text-slate-500">Code</p>
                                <p class="mt-1 text-xl font-black text-slate-950">${getStatusCodeLabel(monitor.statusCode)}</p>
                            </div>
                            <div class="rounded-lg bg-slate-50 p-3">
                                <p class="text-xs font-bold uppercase text-slate-500">Response</p>
                                <p class="mt-1 text-xl font-black text-slate-950">${monitor.responseTime || 0}ms</p>
                            </div>
                            <div class="rounded-lg bg-slate-50 p-3">
                                <p class="text-xs font-bold uppercase text-slate-500">Failures</p>
                                <p class="mt-1 text-xl font-black text-slate-950">${monitor.failureCount || 0}</p>
                            </div>
                            <div class="rounded-lg bg-slate-50 p-3">
                                <p class="text-xs font-bold uppercase text-slate-500">Last check</p>
                                <p class="mt-1 text-sm font-bold text-slate-700">${formatDate(monitor.lastChecked)}</p>
                            </div>
                        </div>

                        <div class="flex flex-wrap gap-2 xl:justify-end">
                            <button class="edit-monitor inline-flex min-h-10 items-center justify-center gap-2 rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm font-bold text-slate-700 transition hover:border-teal-600 hover:text-teal-700" data-id="${monitor._id}" type="button">
                                <i data-lucide="pencil" class="h-4 w-4"></i>
                                Edit
                            </button>
                            <button class="view-logs inline-flex min-h-10 items-center justify-center gap-2 rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm font-bold text-slate-700 transition hover:border-teal-600 hover:text-teal-700" data-id="${monitor._id}" type="button">
                                <i data-lucide="history" class="h-4 w-4"></i>
                                Logs
                            </button>
                            <button class="delete-monitor inline-flex min-h-10 items-center justify-center gap-2 rounded-lg border border-rose-100 bg-rose-50 px-3 py-2 text-sm font-bold text-rose-700 transition hover:bg-rose-100" data-id="${monitor._id}" type="button">
                                <i data-lucide="trash-2" class="h-4 w-4"></i>
                                Delete
                            </button>
                        </div>
                    </div>
                `;

                monitorList.appendChild(card);
            });

            refreshIcons();
        }

        async function loadMonitors() {
            try {
                const data = await apiRequest("/api/monitors/getMonitor");
                const monitors = data.monitor || [];
                currentMonitors = monitors;
                renderMonitors(monitors);
                updateCounts(monitors);
            } catch (error) {
                showMessage(error.message, "error");
            }
        }

        registerForm.addEventListener("submit", async (event) => {
            event.preventDefault();
            hideMessage();

            try {
                const body = getFormData(registerForm);
                await apiRequest("/api/auth/register", {
                    method: "POST",
                    body: JSON.stringify(body),
                });
                registerForm.reset();
                showMessage("Account created. Login with your User ID and password.");
                setAuthMode("login");
            } catch (error) {
                showMessage(error.message, "error");
            }
        });

        loginForm.addEventListener("submit", async (event) => {
            event.preventDefault();
            hideMessage();

            try {
                const body = getFormData(loginForm);
                const data = await apiRequest("/api/auth/login", {
                    method: "POST",
                    body: JSON.stringify(body),
                });
                setToken(data.token);
                loginForm.reset();
                updateView();
            } catch (error) {
                showMessage(error.message, "error");
            }
        });

        monitorForm.addEventListener("submit", async (event) => {
            event.preventDefault();
            hideMessage();

            try {
                const body = getFormData(monitorForm);
                const monitorId = body.id;
                delete body.id;
                body.interval = Number(body.interval);

                await apiRequest(monitorId ? `/api/monitors/updateMonitor/${monitorId}` : "/api/monitors/createMonitor", {
                    method: monitorId ? "PUT" : "POST",
                    body: JSON.stringify(body),
                });
                resetMonitorForm();
                await loadMonitors();
            } catch (error) {
                showMessage(error.message, "error");
            }
        });

        monitorList.addEventListener("click", async (event) => {
            const deleteButton = event.target.closest(".delete-monitor");
            const editButton = event.target.closest(".edit-monitor");
            const logsButton = event.target.closest(".view-logs");

            if (editButton) {
                const monitor = currentMonitors.find((item) => item._id === editButton.dataset.id);
                if (monitor) editMonitor(monitor);
                return;
            }

            if (logsButton) {
                const monitor = currentMonitors.find((item) => item._id === logsButton.dataset.id);
                if (monitor) openLogs(monitor);
                return;
            }

            if (!deleteButton) return;

            try {
                hideMessage();
                await apiRequest(`/api/monitors/deleteMonitor/${deleteButton.dataset.id}`, {
                    method: "DELETE",
                });
                if (monitorForm.elements.id.value === deleteButton.dataset.id) {
                    resetMonitorForm();
                }
                await loadMonitors();
            } catch (error) {
                showMessage(error.message, "error");
            }
        });

        logoutBtn.addEventListener("click", () => {
            clearToken();
            currentMonitors = [];
            resetMonitorForm();
            closeLogs();
            updateCounts([]);
            renderMonitors([]);
            updateView();
        });

        cancelEditBtn.addEventListener("click", resetMonitorForm);
        closeLogsBtn.addEventListener("click", closeLogs);
        logsModal.addEventListener("click", (event) => {
            if (event.target === logsModal) {
                closeLogs();
            }
        });
        refreshBtn.addEventListener("click", loadMonitors);
        showRegisterBtn.addEventListener("click", () => setAuthMode("register"));
        showLoginBtn.addEventListener("click", () => setAuthMode("login"));
        window.addEventListener("load", refreshIcons);

        setInterval(() => {
            if (getToken()) {
                loadMonitors();
            }
        }, 60000);

        updateView();
    </script>
</body>
</html>
